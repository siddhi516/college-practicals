
; Title: Write an X86/64 ALP to convert 4-digit Hex number into its equivalent BCD number

section .data
    msg1 db "Enter 4-digit Hex Number: ", 0
    len1 equ $-msg1

    msg2 db 10, "Equivalent BCD Number: ", 0
    len2 equ $-msg2

    newline db 10

section .bss
    num resb 17
    bcd resb 10

%macro scall 4
    mov rax, %1
    mov rdi, %2
    mov rsi, %3
    mov rdx, %4
    syscall
%endmacro

section .text
    global _start

_start:
    scall 1, 1, msg1, len1
    scall 0, 0, num, 5        ; read 4 digits + newline

    call ascii_to_hex

    mov rax, rbx              ; move hex value to RAX
    mov rbx, 10               ; divisor = 10
    mov rdi, bcd              ; pointer to BCD buffer

    mov rcx, 0                ; digit counter

loop_bcd:
    mov rdx, 0
    div rbx                   ; RAX / 10
                              ; quotient -> RAX
                              ; remainder -> RDX
    push rdx                  ; store remainder (reverse order)
    inc rcx
    cmp rax, 0
    jne loop_bcd

display_bcd:
    pop rdx
    add dl, 30h               ; convert to ASCII
    mov [rdi], dl
    inc rdi
    loop display_bcd

    scall 1, 1, msg2, len2
    scall 1, 1, bcd, 5        ; print BCD number

    mov rax, 60
    xor rdi, rdi
    syscall

; -----------------------------
; Convert ASCII HEX → Binary
; -----------------------------
ascii_to_hex:
    mov rsi, num              ; pointer to input string
    mov rbx, 0                ; clear result
    mov rcx, 4                ; process 4 hex digits

loop_hex:
    rol rbx, 4                ; shift left 4 bits
    mov al, [rsi]             ; read ASCII digit
    cmp al, 39h               ; check if 0-9
    jbe digit
    sub al, 07h               ; adjust for A-F

digit:
    sub al, 30h               ; convert ASCII → number
    add bl, al                ; add to result

    inc rsi
    loop loop_hex
    ret
