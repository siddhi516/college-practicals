; ALP to find the largest number in an array

section .data
    array db 11h,59h,33h,22h,44h

    msg1 db 10,"ALP to find the largest number in array",10
    msg1_len equ $-msg1

    msg2 db 10,"The Array contains elements:",10
    msg2_len equ $-msg2

    msg3 db 10,10,"The Largest number in the array is:",10
    msg3_len equ $-msg3

    newline db 10
    newline_len equ $-newline

section .bss
    counter resb 1
    result  resb 2     ; only 2 hex digits needed

%macro write 2
    mov rax, 1
    mov rdi, 1
    mov rsi, %1
    mov rdx, %2
    syscall
%endmacro

section .text
    global _start

_start:
    write msg1, msg1_len
    write msg2, msg2_len

; --- Display Array Elements ---
    mov byte [counter], 05
    mov rsi, array

next:
    mov al, [rsi]
    push rsi
    call disp
    pop rsi

    inc rsi
    dec byte [counter]
    jnz next

    write msg3, msg3_len

; --- Find Largest Element ---
    mov byte [counter], 05
    mov rsi, array
    mov al, 0

repeat:
    cmp al, [rsi]
    jg skip
    mov al, [rsi]

skip:
    inc rsi
    dec byte [counter]
    jnz repeat

; AL now contains largest element
    call disp

; --- Exit ---
    mov rax, 60
    xor rdi, rdi
    syscall

; --------------------------------
; Procedure: disp
; Displays AL in 2-digit hexadecimal
; --------------------------------
disp:
    mov bl, al
    mov rdi, result
    mov cx, 02

up1:
    rol bl, 4
    mov al, bl
    and al, 0Fh
    cmp al, 09h
    jg add_37
    add al, 30h
    jmp store

add_37:
    add al, 37h

store:
    mov [rdi], al
    inc rdi
    dec cx
    jnz up1

    write result, 2
    write newline, newline_len
    ret
