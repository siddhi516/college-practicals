; Write a X86/64 ALP to convert 5 digit BCD number into its equivalent hex number

section .data
    msg1 db "Enter 5-digit BCD Number: "
    len1 equ $-msg1

    msg2 db 10,"Equivalent HEX Number: "
    len2 equ $-msg2

    newline db 10

section .bss
    bcd_input  resb 6      ; 5 digits + newline
    hex_output resb 8      ; 8 hex characters

section .text
    global _start

_start:

; 1. Print input message
    mov rax, 1
    mov rdi, 1
    mov rsi, msg1
    mov rdx, len1
    syscall

; 2. Read input
    mov rax, 0
    mov rdi, 0
    mov rsi, bcd_input
    mov rdx, 6
    syscall

; 3. Convert BCD (ASCII) → Binary
    mov rsi, bcd_input
    mov rcx, 5
    xor rax, rax          ; result = 0
    mov rbx, 10

convert_loop:
    mul rbx               ; RAX = RAX * 10

    xor r8, r8
    mov r8b, [rsi]        ; ASCII → digit
    sub r8b, 30h

    add rax, r8
    inc rsi
    loop convert_loop

; 4. Print output message
    mov r9, rax           ; save result

    mov rax, 1
    mov rdi, 1
    mov rsi, msg2
    mov rdx, len2
    syscall

; 5. Convert Binary → HEX ASCII
    mov rbx, r9
    mov rcx, 8
    mov rdi, hex_output

hex_loop:
    rol ebx, 4
    mov al, bl
    and al, 0Fh

    cmp al, 9
    jbe digit
    add al, 7

digit:
    add al, 30h
    mov [rdi], al
    inc rdi
    loop hex_loop

; 6. Print HEX result
    mov rax, 1
    mov rdi, 1
    mov rsi, hex_output
    mov rdx, 8
    syscall

; newline
    mov rax, 1
    mov rdi, 1
    mov rsi, newline
    mov rdx, 1
    syscall

; 7. Exit
    mov rax, 60
    xor rdi, rdi
    syscall
